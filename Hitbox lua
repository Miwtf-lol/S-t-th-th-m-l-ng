--// MI.WTF FULL VIP (HITBOX + AIMLOCK + ESP + MINI UI)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local LP = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = LP:GetMouse()

-- SETTINGS
local HitboxEnabled = false
local AimlockEnabled = false
local ESPEnabled = false

local HitboxSize = 5
local MAX_SIZE = 10

local Target = nil
local ESPs = {}

-- RESET HITBOX
local function resetChar(char)
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp = char.HumanoidRootPart
        hrp.Size = Vector3.new(2,2,1)
        hrp.Transparency = 0
    end
end

-- APPLY HITBOX
local function applyChar(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Died:Connect(function()
            resetChar(char)
        end)
    end
end

-- ESP FUNCTION
local function createESP(player)
    if player == LP then return end

    local function apply(char)
        local head = char:FindFirstChild("Head")
        if not head then return end

        if ESPs[player] then ESPs[player]:Destroy() end

        local bill = Instance.new("BillboardGui")
        bill.Adornee = head
        bill.Size = UDim2.new(0,100,0,40)
        bill.StudsOffset = Vector3.new(0,2,0)
        bill.AlwaysOnTop = true

        local name = Instance.new("TextLabel", bill)
        name.Size = UDim2.new(1,0,1,0)
        name.BackgroundTransparency = 1
        name.Text = player.Name
        name.TextColor3 = Color3.fromRGB(255,100,255)
        name.TextStrokeTransparency = 0
        name.TextScaled = true

        bill.Parent = char
        ESPs[player] = bill
    end

    if player.Character then
        apply(player.Character)
    end

    player.CharacterAdded:Connect(function(char)
        task.wait(1)
        if ESPEnabled then
            apply(char)
        end
    end)
end

-- APPLY PLAYER
for _, v in pairs(Players:GetPlayers()) do
    if v ~= LP then
        if v.Character then applyChar(v.Character) end
        createESP(v)
        v.CharacterAdded:Connect(function(char)
            applyChar(char)
        end)
    end
end

Players.PlayerAdded:Connect(function(v)
    if v ~= LP then
        v.CharacterAdded:Connect(function(char)
            applyChar(char)
        end)
        createESP(v)
    end
end)

-- AIMLOCK
local function getClosest()
    local closest, dist = nil, math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, visible = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if visible then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if mag < dist then
                    dist = mag
                    closest = v
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    -- AIMLOCK
    if AimlockEnabled then
        Target = getClosest()
        if Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character.HumanoidRootPart.Position)
        end
    end

    -- HITBOX
    if HitboxEnabled then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LP and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = v.Character.HumanoidRootPart
                local hum = v.Character:FindFirstChildOfClass("Humanoid")

                if hum and hum.Health > 0 then
                    hrp.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                    hrp.Transparency = 0.7
                    hrp.CanCollide = false
                end
            end
        end
    end
end)

-- RESET ALL
local function resetAll()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character then
            resetChar(v.Character)
        end
    end
end

